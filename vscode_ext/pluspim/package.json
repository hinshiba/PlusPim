{
  "name": "pluspim",
  "displayName": "PlusPim",
  "publisher": "hinshiba",
  "description": "MIPS assembly time-travel debugger",
  "version": "0.1.0",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/hinshiba/PlusPim"
  },
  "engines": {
    "vscode": "^1.108.0"
  },
  "categories": [
    "Debuggers"
  ],
  "activationEvents": [
    "onDebug"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "debuggers": [
      {
        "type": "pluspim",
        "label": "PlusPim Debugger",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": [
                  "string",
                  "array"
                ],
                "items": {
                  "type": "string"
                },
                "description": "Path to the MIPS assembly file (string) or an array of paths. The runtime will normalize either form.",
                "default": [
                  "${file}"
                ]
              },
              "trace": {
                "type": "boolean",
                "description": "Enable DAP communication trace",
                "default": false
              },
              "port": {
                "type": "number",
                "description": "DAP TCP port",
                "default": 4711
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Extra arguments (e.g. [\"--verbose\"])",
                "default": []
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "pluspim",
            "request": "launch",
            "name": "Minimal Launch",
            "program": ["${file}"]
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "package:win32-x64": "node scripts/vsix.mjs win32-x64",
    "package:linux-x64": "node scripts/vsix.mjs linux-x64",
    "dotnet:publish:win": "dotnet publish ../../PlusPim/PlusPim.csproj -c Release -r win-x64 --self-contained -o ./bin/win-x64 -p:DebugType=none -p:DebugSymbols=false",
    "dotnet:publish:linux": "dotnet publish ../../PlusPim/PlusPim.csproj -c Release -r linux-x64 --self-contained -o ./bin/linux-x64 -p:DebugType=none -p:DebugSymbols=false",
    "dotnet:debug:win": "dotnet publish ../../PlusPim/PlusPim.csproj -c Debug -r win-x64 --self-contained -o ./bin/win-x64",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.108.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.2.5",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.1.3",
    "@vscode/test-electron": "^2.3.2"
  }
}