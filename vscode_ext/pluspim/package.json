{
  "name": "pluspim",
  "displayName": "pluspim",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.108.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onDebug"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "debuggers": [
      {
        "type": "pluspim",
        "label": "PlusPim Debugger",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "ファイルへのパス",
                "default": "${file}"
              },
              "trace": {
                "type": "boolean",
                "description": "通信トレースの有効化",
                "default": false
              },
              "port": {
                "type": "number",
                "description": "DAP TCP port",
                "default": 4711
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "追加オプション(例: [\"--verbose\"])",
                "default": []
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "pluspim",
            "request": "launch",
            "name": "Minimal Launch",
            "program": "${file}"
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run dotnet:publish:win && pnpm run dotnet:publish:linux && pnpm run compile",
    "dotnet:publish:win": "dotnet publish ../../PlusPim/PlusPim.csproj -c Release -r win-x64 --self-contained -o ./bin/win-x64",
    "dotnet:publish:linux": "dotnet publish ../../PlusPim/PlusPim.csproj -c Release -r linux-x64 --self-contained -o ./bin/linux-x64",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.108.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.2.5",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.1.3",
    "@vscode/test-electron": "^2.3.2"
  }
}